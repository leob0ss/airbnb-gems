# =============================================================================
# Airbnb Gems — Environment Variables
# =============================================================================
# Copy to .env for local dev:  cp .env.example .env
#
# On Vercel: Project Settings → Environment Variables → add each below.
# =============================================================================

# OPTIONAL — local Express dev server port (default 3000)
PORT=3000

# OPTIONAL — Google Maps (desktop map view). Get key at console.cloud.google.com
VITE_GOOGLE_MAPS_API_KEY=

# REQUIRED for forms (Neon Postgres — Vercel Storage → Neon, or neon.tech)
POSTGRES_URL=

# OPTIONAL — email notifications for survey / contact / filter requests (Resend)
NOTIFY_EMAIL=you@example.com
RESEND_API_KEY=
RESEND_FROM=Airbnb Gems <notifications@yourdomain.com>

# =============================================================================
# Deploy checklist (Vercel)
# =============================================================================
# 1. Push repo to GitHub
# 2. Import project in Vercel (framework: Other, build: pnpm build:client)
# 3. Vercel Storage → connect Neon (sets POSTGRES_URL) + Resend vars above
# 4. Redeploy after env changes
